{
	"schemaVersion": 1,
	"id": "minesier",
	"version": "${version}",
	"name": "MineSIer",
	"description": "In-world JavaScript programming for Minecraft: programmable computers and turtles, in the spirit of CC:Tweaked.",
	"authors": [
		"hodzilla51"
	],
	"contact": {
		"homepage": "https://github.com/hodzilla51/minesier",
		"sources": "https://github.com/hodzilla51/minesier",
		"issues": "https://github.com/hodzilla51/minesier/issues"
	},
	"license": "MIT",
	"icon": "assets/minesier/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.hodzilla51.minesier.MineSIer"
		],
		"client": [
			"com.hodzilla51.minesier.client.MineSIerClient"
		]
	},
	"mixins": [
		"minesier.mixins.json",
		{
			"config": "minesier.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}